@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar Sesion";
    ViewData["ActiveNav"] = "Login";
}

@section Styles {
<style>
    .auth-wrapper {
        min-height: calc(100vh - 200px);
        display: flex;
        align-items: center;
    }
    .brand-panel {
        background: linear-gradient(135deg, #FFF7ED 0%, #FFEDD5 50%, rgba(255, 107, 43, 0.1) 100%);
        border: 1px solid var(--border-color);
        border-radius: 16px 0 0 16px;
        padding: 3rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        min-height: 520px;
        position: relative;
        overflow: hidden;
    }
    .brand-panel::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 70% 30%, rgba(255, 107, 43, 0.08) 0%, transparent 50%);
        pointer-events: none;
    }
    .brand-graphic {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(255, 107, 43, 0.12), rgba(255, 107, 43, 0.04));
        border: 2px solid rgba(255, 107, 43, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 2rem;
    }
    .brand-graphic i {
        font-size: 3.5rem;
        color: var(--accent);
    }
    .form-panel {
        border-radius: 0 16px 16px 0;
        min-height: 520px;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    .auth-divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.25rem 0;
    }
    .auth-divider::before,
    .auth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border-color);
    }
    .auth-divider span {
        font-size: 0.8rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .social-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        padding: 0.6rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        background: var(--bg-secondary);
        color: var(--text-primary);
        font-size: 0.9rem;
        font-weight: 500;
        cursor: not-allowed;
        opacity: 0.6;
        transition: all 0.2s var(--ease-smooth);
    }
    .validation-error {
        background-color: rgba(220, 38, 38, 0.06);
        border: 1px solid rgba(220, 38, 38, 0.2);
        border-radius: 8px;
        padding: 0.75rem 1rem;
        color: #DC2626;
        font-size: 0.85rem;
    }
    .form-floating-custom label {
        color: var(--text-secondary);
    }
    @@media (max-width: 991.98px) {
        .brand-panel {
            display: none !important;
        }
        .form-panel {
            border-radius: 16px;
        }
    }
</style>
}

<section class="auth-wrapper py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10 col-xl-8">
                <div class="row g-0">
                    <!-- Brand Panel (hidden on mobile) -->
                    <div class="col-lg-5 d-none d-lg-flex">
                        <div class="brand-panel w-100">
                            <div class="brand-graphic">
                                <i class="bi bi-graph-up-arrow"></i>
                            </div>
                            <h3 class="fw-bold mb-3" style="color: var(--accent);">Ollin</h3>
                            <p style="color: var(--text-secondary); line-height: 1.7; font-size: 0.95rem;">
                                Inteligencia deportiva avanzada para Liga MX. Accede a analisis cuantitativos,
                                tendencias de mercado y herramientas premium.
                            </p>
                            <div class="mt-4 d-flex flex-column gap-2 text-start w-100" style="max-width: 260px;">
                                <div class="d-flex align-items-center gap-2 small" style="color: var(--text-secondary);">
                                    <i class="bi bi-check-circle-fill" style="color: var(--accent);"></i>
                                    Analisis basados en datos reales
                                </div>
                                <div class="d-flex align-items-center gap-2 small" style="color: var(--text-secondary);">
                                    <i class="bi bi-check-circle-fill" style="color: var(--accent);"></i>
                                    Dashboard personalizado
                                </div>
                                <div class="d-flex align-items-center gap-2 small" style="color: var(--text-secondary);">
                                    <i class="bi bi-check-circle-fill" style="color: var(--accent);"></i>
                                    Alertas en tiempo real
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form Panel -->
                    <div class="col-lg-7">
                        <div class="card-dark form-panel p-4 p-lg-5">
                            <div class="text-center mb-4 d-lg-none">
                                <h4 class="fw-bold mb-1" style="color: var(--accent);">
                                    <i class="bi bi-graph-up-arrow me-2"></i>Ollin
                                </h4>
                            </div>
                            <h4 class="fw-bold mb-1">Bienvenido de vuelta</h4>
                            <p class="mb-4" style="color: var(--text-secondary); font-size: 0.9rem;">
                                Inicia sesion para acceder a tu cuenta
                            </p>

                            <div asp-validation-summary="ModelOnly" class="validation-error mb-3"></div>

                            <form asp-action="Login" method="post">
                                <div class="mb-3">
                                    <label asp-for="Email" class="form-label small fw-bold" style="color: var(--text-secondary);">Email</label>
                                    <div class="input-group">
                                        <span class="input-group-text" style="background: var(--bg-secondary); border-color: var(--border-color); color: var(--text-secondary);">
                                            <i class="bi bi-envelope"></i>
                                        </span>
                                        <input asp-for="Email" class="form-control" placeholder="tu@email.com" autocomplete="email" />
                                    </div>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <label asp-for="Password" class="form-label small fw-bold" style="color: var(--text-secondary);">Contrasena</label>
                                        <a href="#" class="small text-decoration-none" style="font-size: 0.8rem;">Olvidaste tu contrasena?</a>
                                    </div>
                                    <div class="input-group">
                                        <span class="input-group-text" style="background: var(--bg-secondary); border-color: var(--border-color); color: var(--text-secondary);">
                                            <i class="bi bi-lock"></i>
                                        </span>
                                        <input asp-for="Password" class="form-control" placeholder="********" autocomplete="current-password" />
                                    </div>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                                <div class="mb-4">
                                    <div class="form-check">
                                        <input asp-for="RememberMe" class="form-check-input" />
                                        <label asp-for="RememberMe" class="form-check-label small" style="color: var(--text-secondary);">Recordarme</label>
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-accent w-100 py-2 mb-3 fw-bold">
                                    <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesion
                                </button>
                            </form>

                            <div class="auth-divider">
                                <span>o</span>
                            </div>

                            <button class="social-btn" disabled title="Proximamente">
                                <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
                                Continuar con Google
                            </button>

                            <div class="text-center mt-4">
                                <p class="small mb-0" style="color: var(--text-secondary);">
                                    No tienes cuenta?
                                    <a asp-action="Register" class="text-decoration-none fw-semibold">Registrate aqui</a>
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
