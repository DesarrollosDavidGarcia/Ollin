@model BlogPostViewModel
@{
    ViewData["Title"] = Model.Post.Title;
    ViewData["ActiveNav"] = "Blog";
    ViewData["MetaDescription"] = Model.Post.MetaDescription ?? Model.Post.Excerpt;
    ViewData["CanonicalUrl"] = $"/blog/{Model.Post.Slug}";
    ViewData["OgTitle"] = Model.Post.Title;
    ViewData["OgDescription"] = Model.Post.MetaDescription ?? Model.Post.Excerpt;
    if (!string.IsNullOrEmpty(Model.Post.OgImageUrl))
    {
        ViewData["OgImage"] = Model.Post.OgImageUrl;
    }

    int EstimateReadTime(string? bodyHtml)
    {
        if (string.IsNullOrEmpty(bodyHtml)) return 1;
        var text = System.Text.RegularExpressions.Regex.Replace(bodyHtml, "<[^>]+>", " ");
        var wordCount = text.Split(new[] { ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries).Length;
        var minutes = (int)Math.Ceiling(wordCount / 200.0);
        return minutes < 1 ? 1 : minutes;
    }

    var readTime = EstimateReadTime(Model.Post.BodyHtml);
    var shareUrl = System.Net.WebUtility.UrlEncode($"https://ollin.mx/blog/{Model.Post.Slug}");
    var shareTitle = System.Net.WebUtility.UrlEncode(Model.Post.Title);
}

@section Styles {
<style>
    /* Article typography */
    .article-body {
        line-height: 1.9;
        font-size: 1.08rem;
        color: var(--text-primary);
    }
    .article-body h2 {
        font-weight: 700;
        font-size: 1.6rem;
        margin-top: 2.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-primary);
    }
    .article-body h3 {
        font-weight: 600;
        font-size: 1.3rem;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: var(--text-primary);
    }
    .article-body h4 {
        font-weight: 600;
        font-size: 1.1rem;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
    }
    .article-body p {
        margin-bottom: 1.25rem;
    }
    .article-body blockquote {
        border-left: 4px solid var(--accent);
        background: rgba(255, 107, 43, 0.05);
        padding: 1.25rem 1.5rem;
        margin: 1.5rem 0;
        border-radius: 0 8px 8px 0;
        font-style: italic;
        color: var(--text-secondary);
    }
    .article-body blockquote p:last-child {
        margin-bottom: 0;
    }
    .article-body pre {
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1.25rem;
        margin: 1.5rem 0;
        overflow-x: auto;
        font-size: 0.9rem;
    }
    .article-body code {
        background: var(--bg-secondary);
        padding: 0.15rem 0.4rem;
        border-radius: 4px;
        font-size: 0.9em;
        color: var(--accent);
    }
    .article-body pre code {
        background: transparent;
        padding: 0;
        color: var(--text-primary);
    }
    .article-body ul, .article-body ol {
        margin-bottom: 1.25rem;
        padding-left: 1.5rem;
    }
    .article-body li {
        margin-bottom: 0.4rem;
    }
    .article-body img {
        max-width: 100%;
        height: auto;
        border-radius: 8px;
        margin: 1.5rem 0;
    }
    .article-body a {
        color: var(--accent);
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    .article-body table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
    }
    .article-body table th,
    .article-body table td {
        padding: 0.75rem;
        border: 1px solid var(--border-color);
        text-align: left;
    }
    .article-body table th {
        background: var(--bg-secondary);
        font-weight: 600;
    }
    .article-body hr {
        border-color: var(--border-color);
        margin: 2rem 0;
    }

    /* Share buttons */
    .share-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 40px;
        height: 40px;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        text-decoration: none;
        transition: all 0.2s var(--ease-smooth);
        font-size: 1.1rem;
    }
    .share-btn:hover {
        border-color: var(--accent);
        color: var(--accent);
        background: rgba(255, 107, 43, 0.08);
        transform: translateY(-2px);
    }

    /* TOC sidebar */
    .toc-sidebar {
        position: sticky;
        top: 5rem;
    }
    .toc-sidebar .toc-title {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--text-secondary);
        font-weight: 700;
        margin-bottom: 0.75rem;
    }
    .toc-sidebar .toc-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .toc-sidebar .toc-list li {
        margin-bottom: 0.4rem;
    }
    .toc-sidebar .toc-list a {
        font-size: 0.85rem;
        color: var(--text-secondary);
        text-decoration: none;
        display: block;
        padding: 0.25rem 0 0.25rem 0.75rem;
        border-left: 2px solid transparent;
        transition: all 0.2s var(--ease-smooth);
    }
    .toc-sidebar .toc-list a:hover,
    .toc-sidebar .toc-list a.active {
        color: var(--accent);
        border-left-color: var(--accent);
    }
    .toc-sidebar .toc-list .toc-h3 {
        padding-left: 1.5rem;
        font-size: 0.8rem;
    }

    /* Post navigation */
    .post-nav-card {
        flex: 1;
        padding: 1.25rem;
        border-radius: 12px;
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        text-decoration: none;
        transition: all 0.3s var(--ease-smooth);
    }
    .post-nav-card:hover {
        border-color: rgba(255, 107, 43, 0.3);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    /* Author bio */
    .author-bio {
        border-radius: 12px;
        background: linear-gradient(135deg, var(--bg-card), var(--bg-secondary));
        border: 1px solid var(--border-color);
        padding: 1.5rem;
    }
    .author-avatar {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(255, 107, 43, 0.12);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: var(--accent);
        flex-shrink: 0;
    }

    /* Subscribe CTA */
    .subscribe-cta {
        border-radius: 12px;
        background: linear-gradient(135deg, rgba(255, 107, 43, 0.08), rgba(220, 38, 38, 0.04));
        border: 1px solid rgba(255, 107, 43, 0.2);
        padding: 2rem;
        text-align: center;
    }

    .reading-progress {
        position: fixed;
        top: 0;
        left: 0;
        height: 3px;
        background: var(--accent);
        z-index: 9999;
        transition: width 0.1s linear;
        width: 0%;
    }
</style>
}

<div class="reading-progress" id="readingProgress"></div>

<section class="py-5">
    <div class="container">
        <!-- Breadcrumbs -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb mb-0" style="--bs-breadcrumb-divider-color: var(--text-secondary); font-size: 0.85rem;">
                <li class="breadcrumb-item">
                    <a asp-controller="Home" asp-action="Index" style="color: var(--text-secondary); text-decoration: none;">
                        <i class="bi bi-house-door me-1"></i>Inicio
                    </a>
                </li>
                <li class="breadcrumb-item">
                    <a asp-controller="Blog" asp-action="Index" style="color: var(--text-secondary); text-decoration: none;">Blog</a>
                </li>
                @if (Model.Post.Category != null)
                {
                    <li class="breadcrumb-item">
                        <a asp-controller="Blog" asp-action="Index" asp-route-category="@Model.Post.Category.Slug"
                           style="color: var(--text-secondary); text-decoration: none;">@Model.Post.Category.Name</a>
                    </li>
                }
                <li class="breadcrumb-item active" style="color: var(--accent);">@Model.Post.Title</li>
            </ol>
        </nav>

        <div class="row">
            <!-- Article -->
            <div class="col-lg-8">
                <article>
                    <header class="mb-4">
                        @if (Model.Post.Category != null)
                        {
                            <span class="badge badge-accent mb-3">@Model.Post.Category.Name</span>
                        }
                        <h1 class="display-5 fw-bold mb-3" style="line-height: 1.2;">@Model.Post.Title</h1>
                        <div class="d-flex flex-wrap align-items-center gap-3 mb-3" style="color: var(--text-secondary);">
                            @if (Model.Post.Author != null)
                            {
                                <span>
                                    <i class="bi bi-person-circle me-1"></i>
                                    @(Model.Post.Author.UserName)
                                </span>
                            }
                            @if (Model.Post.PublishedAt.HasValue)
                            {
                                <span>
                                    <i class="bi bi-calendar3 me-1"></i>
                                    @Model.Post.PublishedAt.Value.ToString("dd MMMM yyyy")
                                </span>
                            }
                            <span>
                                <i class="bi bi-clock me-1"></i>
                                @readTime min de lectura
                            </span>
                            <span>
                                <i class="bi bi-eye me-1"></i>
                                @Model.Post.ViewCount vistas
                            </span>
                        </div>

                        <!-- Share buttons -->
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <span class="small me-1" style="color: var(--text-secondary);">Compartir:</span>
                            <a href="https://twitter.com/intent/tweet?url=@shareUrl&text=@shareTitle"
                               target="_blank" rel="noopener noreferrer" class="share-btn" title="Compartir en X">
                                <i class="bi bi-twitter-x"></i>
                            </a>
                            <a href="https://www.facebook.com/sharer/sharer.php?u=@shareUrl"
                               target="_blank" rel="noopener noreferrer" class="share-btn" title="Compartir en Facebook">
                                <i class="bi bi-facebook"></i>
                            </a>
                            <a href="https://api.whatsapp.com/send?text=@shareTitle%20@shareUrl"
                               target="_blank" rel="noopener noreferrer" class="share-btn" title="Compartir en WhatsApp">
                                <i class="bi bi-whatsapp"></i>
                            </a>
                            <button class="share-btn" title="Copiar enlace" id="copyLinkBtn" style="cursor:pointer; background:none;">
                                <i class="bi bi-link-45deg"></i>
                            </button>
                        </div>
                    </header>

                    @if (!string.IsNullOrEmpty(Model.Post.OgImageUrl))
                    {
                        <div class="mb-4" style="border-radius: 12px; overflow: hidden;">
                            <img src="@Model.Post.OgImageUrl" alt="@Model.Post.Title"
                                 class="img-fluid w-100" style="max-height: 420px; object-fit: cover;" />
                        </div>
                    }

                    <div class="card-dark p-4 p-lg-5 mb-4 article-body">
                        @Html.Raw(Model.Post.BodyHtml)
                    </div>

                    <!-- Tags -->
                    @if (Model.Post.Tags.Any())
                    {
                        <div class="mb-4">
                            <i class="bi bi-tags me-2" style="color: var(--text-secondary);"></i>
                            @foreach (var tag in Model.Post.Tags)
                            {
                                <a asp-controller="Blog" asp-action="Index" asp-route-tag="@tag.BlogTag.Slug"
                                   class="badge bg-secondary text-decoration-none me-1 mb-1"
                                   style="font-weight: 500; padding: 0.4rem 0.7rem;">
                                    @tag.BlogTag.Name
                                </a>
                            }
                        </div>
                    }

                    <!-- Author Bio -->
                    @if (Model.Post.Author != null)
                    {
                        <div class="author-bio d-flex align-items-start gap-3 mb-4">
                            <div class="author-avatar">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <div>
                                <div class="fw-bold mb-1">@(Model.Post.Author.UserName)</div>
                                <p class="small mb-0" style="color: var(--text-secondary); line-height: 1.6;">
                                    Autor en Ollin. Analisis cuantitativo y tendencias de mercado en Liga MX.
                                </p>
                            </div>
                        </div>
                    }

                    <!-- Subscribe CTA -->
                    <div class="subscribe-cta mb-5">
                        <i class="bi bi-bell display-5 d-block mb-3" style="color: var(--accent);"></i>
                        <h5 class="fw-bold mb-2">Suscribete para mas analisis</h5>
                        <p class="small mb-3 mx-auto" style="color: var(--text-secondary); max-width: 420px;">
                            Recibe nuestros mejores articulos sobre Liga MX, tendencias de mercado y educacion sobre value betting.
                        </p>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="/blog/rss" class="btn btn-outline-accent btn-sm">
                                <i class="bi bi-rss me-1"></i>RSS Feed
                            </a>
                            <a asp-controller="Account" asp-action="Register" class="btn btn-accent btn-sm">
                                <i class="bi bi-person-plus me-1"></i>Crear cuenta
                            </a>
                        </div>
                    </div>

                    <!-- Post Navigation: Anterior / Siguiente -->
                    @if (Model.RelatedPosts.Any())
                    {
                        <div class="d-flex gap-3 mb-5 flex-column flex-md-row">
                            @if (Model.RelatedPosts.Count > 0)
                            {
                                <a asp-controller="Blog" asp-action="Post" asp-route-slug="@Model.RelatedPosts[0].Slug"
                                   class="post-nav-card text-decoration-none">
                                    <small style="color: var(--text-secondary);"><i class="bi bi-arrow-left me-1"></i>Anterior</small>
                                    <div class="fw-bold mt-1" style="font-size: 0.95rem; color: var(--text-heading);">@Model.RelatedPosts[0].Title</div>
                                </a>
                            }
                            @if (Model.RelatedPosts.Count > 1)
                            {
                                <a asp-controller="Blog" asp-action="Post" asp-route-slug="@Model.RelatedPosts[1].Slug"
                                   class="post-nav-card text-decoration-none text-md-end">
                                    <small style="color: var(--text-secondary);">Siguiente<i class="bi bi-arrow-right ms-1"></i></small>
                                    <div class="fw-bold mt-1" style="font-size: 0.95rem; color: var(--text-heading);">@Model.RelatedPosts[1].Title</div>
                                </a>
                            }
                        </div>
                    }
                </article>
            </div>

            <!-- TOC Sidebar -->
            <div class="col-lg-4 d-none d-lg-block">
                <div class="toc-sidebar" id="tocSidebar">
                    <div class="card-dark p-4">
                        <div class="toc-title"><i class="bi bi-list-nested me-2"></i>Contenido</div>
                        <ul class="toc-list" id="tocList">
                            <!-- Populated by JS -->
                        </ul>
                        <div id="tocEmpty" class="small" style="color: var(--text-secondary); display: none;">
                            Sin secciones detectadas.
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Related Posts -->
        @if (Model.RelatedPosts.Any())
        {
            <hr style="border-color: var(--border-color);" class="my-5" />
            <div class="mb-5">
                <h4 class="fw-bold mb-4">Articulos relacionados</h4>
                <div class="row g-4">
                    @foreach (var related in Model.RelatedPosts.Take(3))
                    {
                        <div class="col-md-4">
                            <div class="card-dark h-100 d-flex flex-column">
                                @if (!string.IsNullOrEmpty(related.OgImageUrl))
                                {
                                    <img src="@related.OgImageUrl" alt="@related.Title" loading="lazy"
                                         class="img-fluid" style="border-radius: 12px 12px 0 0; height: 150px; object-fit: cover; width: 100%;" />
                                }
                                <div class="p-3 d-flex flex-column flex-grow-1">
                                    <span class="badge badge-accent mb-2 align-self-start" style="font-size: 0.7rem;">
                                        @related.Category?.Name
                                    </span>
                                    <h6 class="fw-bold mb-2">
                                        <a asp-controller="Blog" asp-action="Post" asp-route-slug="@related.Slug"
                                           class="text-decoration-none stretched-link" style="color: var(--text-heading);">
                                            @related.Title
                                        </a>
                                    </h6>
                                    <small class="mt-auto" style="color: var(--text-secondary);">
                                        @related.PublishedAt?.ToString("dd MMM yyyy")
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@section Scripts {
    @if (!string.IsNullOrEmpty(Model.ArticleJsonLd))
    {
        <script type="application/ld+json">
            @Html.Raw(Model.ArticleJsonLd)
        </script>
    }
    @if (!string.IsNullOrEmpty(Model.BreadcrumbJsonLd))
    {
        <script type="application/ld+json">
            @Html.Raw(Model.BreadcrumbJsonLd)
        </script>
    }

    <script>
        // Table of Contents generation
        (function () {
            var article = document.querySelector('.article-body');
            var tocList = document.getElementById('tocList');
            var tocEmpty = document.getElementById('tocEmpty');
            if (!article || !tocList) return;

            var headings = article.querySelectorAll('h2, h3');
            if (headings.length === 0) {
                tocEmpty.style.display = 'block';
                return;
            }

            headings.forEach(function (h, i) {
                var id = 'section-' + i;
                h.id = id;
                var li = document.createElement('li');
                var a = document.createElement('a');
                a.href = '#' + id;
                a.textContent = h.textContent;
                if (h.tagName === 'H3') a.classList.add('toc-h3');
                li.appendChild(a);
                tocList.appendChild(li);
            });

            // Highlight active section on scroll
            var tocLinks = tocList.querySelectorAll('a');
            window.addEventListener('scroll', function () {
                var current = '';
                headings.forEach(function (h) {
                    if (h.getBoundingClientRect().top <= 120) {
                        current = h.id;
                    }
                });
                tocLinks.forEach(function (link) {
                    link.classList.toggle('active', link.getAttribute('href') === '#' + current);
                });
            });
        })();

        // Copy link button
        (function () {
            var btn = document.getElementById('copyLinkBtn');
            if (!btn) return;
            btn.addEventListener('click', function () {
                navigator.clipboard.writeText(window.location.href).then(function () {
                    var icon = btn.querySelector('i');
                    icon.className = 'bi bi-check-lg';
                    btn.style.color = 'var(--accent)';
                    btn.style.borderColor = 'var(--accent)';
                    setTimeout(function () {
                        icon.className = 'bi bi-link-45deg';
                        btn.style.color = '';
                        btn.style.borderColor = '';
                    }, 2000);
                });
            });
        })();

        // Reading progress bar
        (function () {
            var bar = document.getElementById('readingProgress');
            var article = document.querySelector('.article-body');
            if (!bar || !article) return;
            window.addEventListener('scroll', function () {
                var rect = article.getBoundingClientRect();
                var total = article.offsetHeight;
                var scrolled = Math.max(0, -rect.top);
                var pct = Math.min(100, (scrolled / (total - window.innerHeight * 0.5)) * 100);
                bar.style.width = pct + '%';
            });
        })();
    </script>
}
